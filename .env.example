# Content Pipeline 스킬 설정
# 이 파일을 .env로 복사한 후 값을 입력하세요: cp .env.example .env

# [필수] 이미지 생성용 API 키 (Google AI Studio에서 발급)
# https://aistudio.google.com/apikey
NANOBANANA_API_KEY=

# [선택] 이미지 생성 모델 (기본: gemini-3-pro-image-preview)
NANOBANANA_MODEL=gemini-3-pro-image-preview

# [선택] 기본 이미지 비율 (옵션: 1:1, 16:9, 9:16, 4:3, 3:4, 4:1, 1:4)
NANOBANANA_ASPECT_RATIO=

# [선택] 기본 이미지 크기 (옵션: 512, 1K, 2K, 4K)
NANOBANANA_IMAGE_SIZE=

# [선택] 사고 수준 (옵션: minimal, high)
NANOBANANA_THINKING_LEVEL=high

# [선택] API 타임아웃 (초)
NANOBANANA_TIMEOUT=120

# [필수] OpenAI API 키 (TTS 음성 생성용)
# https://platform.openai.com/api-keys
OPENAI_API_KEY=
